# web-researcher-mcp — Environment Configuration
# Copy to .env and fill in your values

# ── Required: Google Custom Search ───────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CUSTOM_SEARCH_API_KEY=AIzaSy...your-key-here...
# Get from: https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_ID=017576662512468239146:omuauf_gy1x

# ── Search Provider (default: google) ────────────────────────────────────────
# Options: google, brave, serper, searxng, searchapi, tavily
# SEARCH_PROVIDER=brave
# BRAVE_API_KEY=BSA...
# SERPER_API_KEY=...
# SEARCHAPI_API_KEY=...
# TAVILY_API_KEY=tvly-...
# SEARXNG_URL=http://localhost:8080
# SEARCH_FALLBACK_PROVIDER=google

# ── Multi-Provider Routing (optional) ───────────────────────────────────────
# When set, enables intelligent routing with automatic fallback.
# Simple format (comma-separated priority list):
# SEARCH_ROUTING=brave,google,serper,tavily
# Advanced format (per-operation JSON):
# SEARCH_ROUTING={"web":"brave,google","news":"brave,serper","images":"google,brave","academic":"searchapi,google","patents":"searchapi,google","default":"brave,google,searchapi"}

# ── HTTP Transport (optional — enables multi-client mode) ────────────────────
# PORT=3000
# OAUTH_ISSUER_URL=https://auth.example.com
# OAUTH_AUDIENCE=https://api.example.com
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ── Cache ────────────────────────────────────────────────────────────────────
# CACHE_DIR=./cache
# CACHE_MAX_MEMORY_MB=64
# CACHE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# REDIS_URL=redis://localhost:6379

# ── Rate Limiting (HTTP mode only — STDIO has no internal rate limiting) ──────
# RATE_LIMIT_PER_TENANT=120
# RATE_LIMIT_GLOBAL=1000
# DAILY_QUOTA_PER_TENANT=5000

# ── Scraping ─────────────────────────────────────────────────────────────────
# ALLOW_PRIVATE_IPS=false
# ALLOWED_DOMAINS=example.com,docs.example.com
# CHROME_PATH=/usr/bin/chromium
# MAX_SCRAPE_CONCURRENCY=5

# ── Search Lenses ────────────────────────────────────────────────────────────
# CUSTOM_LENSES_PATH=/path/to/custom/lenses

# ── Observability ────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_FORMAT=json
# METRICS_ENABLED=true

# ── Multi-Tenancy ────────────────────────────────────────────────────────────
# CACHE_ISOLATION=shared

# ── Audit ────────────────────────────────────────────────────────────────────
# AUDIT_ENABLED=true
# AUDIT_OUTPUT_PATH=/var/log/web-researcher-mcp/audit.jsonl
# AUDIT_BUFFER_SIZE=1000
# AUDIT_INCLUDE_REQUEST_BODY=false

# ── Auth (advanced) ──────────────────────────────────────────────────────────
# JWKS_REFRESH_INTERVAL=1h

# ── Admin ────────────────────────────────────────────────────────────────────
# CACHE_ADMIN_KEY=your-secure-admin-key-minimum-16-chars
