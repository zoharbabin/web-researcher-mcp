# web-researcher-mcp — Environment Configuration
# Copy to .env and fill in your values

# ── Google Custom Search (optional) ──────────────────────────────────────────
# Required ONLY when SEARCH_PROVIDER=google (without SEARCH_ROUTING). Leave unset
# to run keyless: the server falls back to the zero-config DuckDuckGo provider.
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-api-key-here
# Get from: https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_ID=your-search-engine-id

# ── Search Provider (variable default: google; resolves to zero-config ───────
# ── DuckDuckGo at runtime when google is selected but no key is set) ──────────
# Options: google, brave, serper, searxng, searchapi, duckduckgo, tavily, exa, hackernews, github
# DuckDuckGo requires no API key (works immediately, rate-limited for heavy use)
# SEARCH_PROVIDER=hackernews  — no key required; searches HN stories via Algolia
# SEARCH_PROVIDER=github      — no key required; searches GitHub issues+PRs via REST Search API
# Optional: raises GitHub Search API rate limit from 10→30 req/min (see GITHUB_TOKEN below)
# SEARCH_PROVIDER=brave
# BRAVE_API_KEY=BSA...
# Optional: return extra_snippets (up to 5 additional snippets per result, uses more tokens). Default: false.
# BRAVE_EXTRA_SNIPPETS=false
# SERPER_API_KEY=...
# SEARCHAPI_API_KEY=...
# TAVILY_API_KEY=tvly-...   # search API built for AI agents; clean LLM-ready content (get from app.tavily.com)
# EXA_API_KEY=...           # neural/semantic search; paid per call (get from dashboard.exa.ai).
#                           # Also backs: academic_search (research-paper category), the provider-
#                           # independent `answer` (grounded Q&A) and `structured_search` (schema
#                           # extraction + company entities) tools, and a paid /contents fallback
#                           # tier for scrape_page.
# SEARXNG_URL=http://localhost:8080
# If your SearXNG sits behind HTTP Basic auth (issue #109), supply the credential:
# SEARXNG_BASIC_AUTH=user:password
# For non-Basic schemes (bearer token, Cloudflare Access, API-gateway secret), set
# static request headers as comma-separated "Name: Value" pairs (no commas or
# newlines inside a value; a custom Authorization header overrides SEARXNG_BASIC_AUTH):
# SEARXNG_HEADERS=X-Proxy-Token: abc123, CF-Access-Client-Id: client.id

# ── Academic Search Providers (optional, enables rich scholarly metadata) ────
# These provide structured access to scholarly databases with DOIs, authors,
# citation counts, abstracts, and open-access indicators.
# When configured, academic_search uses these instead of site-restricted web search.
# OPENALEX_EMAIL=you@example.com     # 287M+ works, all disciplines (100 RPS polite pool)
# CROSSREF_EMAIL=you@example.com     # 140M+ DOI-registered works, 99.94% uptime (50 RPS polite pool)
# SEMANTIC_SCHOLAR_API_KEY=...       # 200M+ papers + tldr summaries + citation intent/influence;
#                                    # works WITHOUT a key at a lower shared rate. Also powers the
#                                    # citation_graph tool (get one at semanticscholar.org/product/api).
# PubMed (NCBI E-utilities) — biomedical literature; ALWAYS available (keyless, ~3 req/s).
# PUBMED_API_KEY=...                 # optional: raises the rate (~10 req/s). Get one at
#                                    # ncbi.nlm.nih.gov/account (Settings → API Key Management).
# PUBMED_EMAIL=you@example.com       # optional NCBI contact (recommended); falls back to OPENALEX_EMAIL.
# (Exa also serves academic_search via the research-paper category when EXA_API_KEY is set —
#  a neural-web alternate to the above, not a curated bibliographic database.)
#
# Open-access enrichment (Unpaywall) — fills free-PDF links on DOI-bearing
# academic_search results that lack one. Best-effort, no-op when unset.
# UNPAYWALL_EMAIL=you@example.com    # required contact email (falls back to OPENALEX_EMAIL if unset)

# ── Patent Search Providers (optional, enables structured patent search) ────
# These provide direct access to official patent databases with structured results.
# When configured, patent_search uses these instead of web search fallback.
# USPTO_API_KEY=...                  # US patents (get from data.uspto.gov)
# EPO_OPS_CONSUMER_KEY=...           # Worldwide patents (register at developers.epo.org)
# EPO_OPS_CONSUMER_SECRET=...
# LENS_API_TOKEN=...                 # Worldwide + scholarly links (register at lens.org)

# ── Structured-Domain Providers (optional, enable filing/case/economic search) ──
# EDGAR_CONTACT_EMAIL=you@example.com  # enables filing_search (SEC EDGAR). SEC requires a
#                                      # contact email in the request User-Agent; no API key.
#                                      # Falls back to OPENALEX_EMAIL; filing_search registers
#                                      # only when one of them is set.
# COURTLISTENER_API_TOKEN=...          # legal_search (CourtListener) is ALWAYS available; it
#                                      # works keyless (~100 req/day). Set a token to raise the
#                                      # limit (~5000/day). Get one at courtlistener.com.
# FRED_API_KEY=...                     # econ_search is ALWAYS available (keyless World Bank global
#                                      # indicators, OECD economy indicators, and Eurostat European
#                                      # statistics). Set this to ADD FRED's 800K+ US macro series.
#                                      # Free key at fred.stlouisfed.org.
#                                      # clinical_search (ClinicalTrials.gov) is ALWAYS available too —
#                                      # keyless, no env var.

# ── Internet Archive Save Page Now (optional, archive_source) ───────────────
# archive_source is ALWAYS available and works KEYLESS (Save Page Now is rate-
# limited then). Set BOTH keys to authenticate captures for higher reliability.
# Get an S3-style key pair at archive.org/account/s3.php. Never logged or echoed.
# IA_ACCESS_KEY=...
# IA_SECRET_KEY=...

# ── BrandFetch (optional, brand_research) ───────────────────────────────────
# brand_research is ALWAYS available and works without a key (falls back to
# CSS extraction, homepage meta, and brand-page probing). Set a key for
# authoritative color/font/logo data from the BrandFetch Brand + Context APIs.
# Free tier: 100 API req/month. Logo CDN: 500K req/month.
# Get a key at: https://developers.brandfetch.com — Never logged or echoed.
# BRANDFETCH_API_KEY=pk_...
# BRANDFETCH_CLIENT_ID=...

# ── ecosyste.ms (optional, awesome_list_search) ─────────────────────────────
# awesome_list_search is ALWAYS available and works keyless at a shared
# "anonymous" rate limit. Setting ECOSYSTEMS_EMAIL opts into ecosyste.ms's
# "polite pool" (a real rate-limit increase on the free tier); it falls back
# to OPENALEX_EMAIL when unset. ECOSYSTEMS_API_KEY is sent too but only takes
# effect on ecosyste.ms's paid Develop/Scale plans, not the free self-service
# keys from ecosyste.ms/login — kept for forward compatibility. Never logged.
# ECOSYSTEMS_EMAIL=...
# ECOSYSTEMS_API_KEY=...

# ── GitHub (optional, awesome_list_search + SEARCH_PROVIDER=github + scrape_page) ───
# GITHUB_TOKEN is purely optional, exactly like ECOSYSTEMS_API_KEY /
# BRANDFETCH_API_KEY above — every GitHub API surface it touches already
# works unauthenticated at GitHub's documented public rate limit; setting it
# only raises that ceiling, never gates functionality. No gh CLI, no
# subprocess, no transport-dependent behavior. Used by: the GitHub topic-
# search fallback in awesome_list_search (#394), the github search.Provider
# (SEARCH_PROVIDER=github, #282), and native GitHub content routing in
# scrape_page (#395). Create a fine-grained personal access token with no
# scopes (public data only) at https://github.com/settings/tokens — never
# logged.
# GITHUB_TOKEN=ghp_...

# ── Multi-Provider Routing (optional) ───────────────────────────────────────
# When set, enables intelligent routing with automatic fallback.
# Simple format (comma-separated priority list):
# SEARCH_ROUTING=brave,google,serper
# Advanced format (per-operation JSON):
# SEARCH_ROUTING={"web":"brave,google","news":"brave,serper","images":"google,brave","academic":"searchapi,google","patents":"epo,lens,searchapi,uspto","default":"brave,google,searchapi"}
# SEARCH_THIN_THRESHOLD=1
# When SEARCH_ROUTING is active, retry the same provider with a stop-word-stripped
# query if result count <= this threshold. Default: 1. Set 0 to disable.

# ── HTTP Transport (optional — enables multi-client mode) ────────────────────
# PORT=3000
# OAUTH_ISSUER_URL=https://auth.example.com
# OAUTH_AUDIENCE=https://api.example.com
# ALLOWED_ORIGINS=https://example.com,https://app.example.com
# CORS is browser-only and fail-closed by default (CORS_STRICT=true): an empty
# ALLOWED_ORIGINS denies all cross-origin browser requests. Set ALLOWED_ORIGINS
# to your browser client's origin to allow it. Backend-to-backend connectors
# (e.g. ChatGPT/Claude.ai hosted connectors), SDKs, and STDIO are unaffected by
# CORS. Set CORS_STRICT=false to restore the legacy permissive reflect-any-Origin
# behavior. See docs/MIGRATION.md for the breaking-change details.
# CORS_STRICT=false
# ENFORCE_SCOPES=false               # When true, tokens carrying a scope/scp claim
#                                    # must include tool:* or tool:<name> (or 'research')
#                                    # to invoke a tool; tokens with NO scope claim are
#                                    # still allowed (permissive, fail-closed only on
#                                    # present-but-insufficient scopes).
# REQUIRED_SCOPES=                   # Optional CSV of scopes required when ENFORCE_SCOPES=true

# ── HTTP Hardening (HTTP mode only — all ignored when PORT is unset) ──────────
# Defaults are permissive so long scrape/research responses are never truncated.
# HTTP_READ_HEADER_TIMEOUT=5s        # Slowloris guard; max time to read request headers
# HTTP_READ_TIMEOUT=30s              # Max time to read the full request
# HTTP_WRITE_TIMEOUT=0               # 0 = unlimited (keep permissive for long responses)
# HTTP_IDLE_TIMEOUT=120s             # Frees idle keep-alive connections
# HTTP_SHUTDOWN_TIMEOUT=30s          # Grace period to drain in-flight requests on SIGINT/SIGTERM before hard close
# HTTP_MAX_HEADER_BYTES=1048576      # Caps header size (1MB) against header-flood
# MAX_REQUEST_BODY_BYTES=10485760    # Rejects oversized /mcp and /admin request bodies (10MB)
# HTTP_CSP=default-src 'none'; frame-ancestors 'none'   # Content-Security-Policy header (empty omits)
# HTTP_REFERRER_POLICY=no-referrer   # Referrer-Policy header
# HTTP_PERMISSIONS_POLICY=geolocation=(), camera=(), microphone=()   # Permissions-Policy (empty omits)

# ── Cache ────────────────────────────────────────────────────────────────────
# CACHE_DIR=/custom/path  # Default: ~/Library/Caches/web-researcher-mcp (macOS), ~/.cache/web-researcher-mcp (Linux)
# CACHE_MAX_MEMORY_MB=64
# CACHE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Optional 64-hex previous key for zero-downtime key rotation. When set, the disk
# cache and session store decrypt-fallback to it and lazily re-encrypt with the
# current key on read. Empty = no fallback.
# CACHE_ENCRYPTION_KEY_PREV=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
# REDIS_URL (HTTP mode only) enables distributed state across pods: shared cache
# L2, cross-pod sessions (survive restarts), and atomic fleet-wide daily quota.
# Requires CACHE_ENCRYPTION_KEY (personal data is encrypted at rest in Redis).
# Fail-fast: an unreachable Redis at startup is fatal (no silent per-pod fallback).
# Unset = per-pod in-memory/disk (unchanged). Ignored in STDIO mode.
# REDIS_URL=redis://localhost:6379

# ── Session Persistence ──────────────────────────────────────────────────────
# SESSION_TTL=4h                     # Session idle timeout (resets on each step)
# SESSION_DATA_DIR=                  # Encrypted session storage (default: {CACHE_DIR}/sessions)
# SESSION_MAX_STEPS=200              # Max steps per research session

# ── Rate Limiting (HTTP mode only — STDIO has no internal rate limiting) ──────
# RATE_LIMIT_PER_TENANT=120
# RATE_LIMIT_GLOBAL=1000
# DAILY_QUOTA_PER_TENANT=5000
# MAX_CALLS_PER_DAY=0                 # In-process per-(tenant,user) daily tool-call
#                                    # ceiling — a denial-of-wallet backstop that ALSO
#                                    # applies in STDIO (where the HTTP limits don't run).
#                                    # 0 = disabled (default). Local per-process count,
#                                    # resets at the UTC day; pair with provider billing caps.
# RATE_LIMIT_PER_IP=0                 # Requests/min per client IP, enforced PRE-auth.
#                                    # 0 = disabled (default). Set generous (hundreds)
#                                    # for public HTTP; never blocks zero-config use.
# TRUST_PROXY=false                  # When true, the per-IP limiter trusts the leftmost
#                                    # X-Forwarded-For entry (behind a trusted LB).
# RATE_LIMIT_PERSIST=false           # When true, daily quota counters write through to
#                                    # the encrypted persist store and survive restarts.

# ── Scraping ─────────────────────────────────────────────────────────────────
# ALLOW_PRIVATE_IPS=false
# ALLOWED_DOMAINS=example.com,docs.example.com
# CHROME_PATH=/usr/bin/chromium    # Explicit Chromium path. Empty = autodetect.
                                    # Set to "disabled" to turn the browser
                                    # rendering tier off entirely (no autodetect,
                                    # no download) for hardened/headless deploys.
# MAX_SCRAPE_CONCURRENCY=5
# MAX_HTML_BYTES sets the decompressed HTML body read cap per tier (default 8388608 = 8 MB)
# MAX_DOCUMENT_BYTES sets the document (PDF/DOCX/PPTX) download cap (default 52428800 = 50 MB)

# ── Search Lenses ────────────────────────────────────────────────────────────
# A directory of your own lens JSON files (same shape as the bundled lenses/),
# loaded AFTER the bundled set so a custom lens can extend OR override a bundled
# one (last write wins — e.g. drop in your org's allowlisted-source lens). Each
# file is schema-validated at startup; an invalid lens fails startup in HTTP mode
# so a typo'd governance lens never silently fails to restrict a search. See
# lenses/README.md for the schema + authoring guide.
# CUSTOM_LENSES_PATH=/path/to/custom/lenses

# ── Output Features (additive; content-only, no personal data) ───────────────
# SOURCE_RECOMMENDATIONS=true   # Advisory "related higher-quality sources" on
#                               # search_and_scrape, from the transparent quality
#                               # signals. Content-based, never re-ranks results.
#                               # Default true; set false to omit the field.
# GENERATIVE_UI_ENABLED=false   # Additive AI-formatted components (source cards,
#                               # quality-comparison table) built deterministically
#                               # from extracted data (no server LLM call). Each is
#                               # labelled autoFormatted ("mcp-auto-formatted") and
#                               # references raw sources. Default false; output
#                               # unchanged when off.

# ── Regulated Features (HTTP mode; opt-in, default off, consent-gated) ───────
# These process per-user personal data. Enabling ANY of them activates the
# consent subsystem (#89): every per-user write requires a recorded, granted
# consent for its purpose, and all stored data is covered by the data-subject
# rights endpoints (#85, GET/DELETE /admin/data). Consent is ASSERTED by the
# host (per the MCP spec, the host obtains consent) and RECORDED/VERIFIED/HONORED
# here. There is no standalone CONSENT_ENABLED knob — consent activates with the
# feature. When all are off, behavior is byte-for-byte unchanged.
# MEMORY_ENABLED=false           # #88 opt-in long-term cross-session memory
# MEMORY_RETENTION=2160h         # Max lifetime of a saved memory before auto-expiry (default 90d)
# USER_ANALYTICS_ENABLED=false   # #92 opt-in per-user usage analytics
# WORKSPACES_ENABLED=false       # #96 opt-in shared research workspaces
# WORKSPACE_TTL=720h             # Max lifetime of shared-workspace data (default 30d)
#
# STDIO_USER_ID=                 # STDIO-only: names the single local user so the
#                                # per-user regulated features (memory, analytics)
#                                # work without OAuth. STDIO has no identity, so by
#                                # default the user is "anonymous" and those features
#                                # stay off. Setting this is the operator asserting
#                                # their OWN identity. When set (+ the relevant feature
#                                # flag on), the server AUTO-GRANTS consent for memory
#                                # and analytics ONLY (never workspace) at startup —
#                                # grant-only-if-absent, so a withdrawal recorded later
#                                # is never re-granted; each grant emits an audited
#                                # consent.grant event. Data lands under data-subject
#                                # key (tenant=default, user=<value>) for /admin/data.
#                                # Allowed: A-Za-z0-9._@- , length 1-128, not "anonymous".
#                                # Ignored in HTTP mode (identity comes from OAuth).

# ── Observability ────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_FORMAT=json
# METRICS_ENABLED=true

# ── Multi-Tenancy ────────────────────────────────────────────────────────────
# CACHE_ISOLATION=shared
# DATA_REGION=                       # Advisory label for where cache/session/audit data
#                                    # resides; surfaced in stats/audit. No functional effect.

# ── Audit ────────────────────────────────────────────────────────────────────
# AUDIT_ENABLED=true
# AUDIT_OUTPUT_PATH=/var/log/web-researcher-mcp/audit.jsonl
# AUDIT_BUFFER_SIZE=1000
# AUDIT_INCLUDE_REQUEST_BODY=false   # When true, raw query text is attached to audit
#                                    # metadata; otherwise only length/hash is recorded.
# AUDIT_MAX_BYTES=104857600          # Rotate active audit file to a timestamped sibling
#                                    # at this size (100MB). File output only.
# AUDIT_RETENTION_DAYS=180           # Delete rotated audit files older than this on startup
#                                    # and hourly. 0 disables cleanup. Clamped to [180,3650].

# ── Auth (advanced) ──────────────────────────────────────────────────────────
# JWKS_REFRESH_INTERVAL=1h

# ── Admin ────────────────────────────────────────────────────────────────────
# Gates all /admin/* endpoints (cache flush, session flush, GDPR data-subject
# rights, tenant analytics, workspace membership). Sent as the X-Admin-Key
# header; compared in constant time. Must be at least 16 characters when set.
# Generate one with: openssl rand -hex 32
# ADMIN_API_KEY=your-secure-admin-key-minimum-16-chars
#
# Deprecated alias (still accepted, logs a startup warning): rename to ADMIN_API_KEY.
# CACHE_ADMIN_KEY=your-secure-admin-key-minimum-16-chars
#
# Key rotation: see docs/DEPLOYMENT.md "Key rotation" for rotating ADMIN_API_KEY
# and the AES-256-GCM CACHE_ENCRYPTION_KEY (CACHE_ENCRYPTION_KEY_PREV enables
# zero-downtime re-encryption of disk-cached data).
