[0.045, "o", "\r\n\r\n"]
[0.208, "o", "  \u001b[1mUS-2025-0142893\u001b[0m — Efficient Transformer Inference on Mobile Devices\r\n"]
[0.000, "o", "  \u001b[2mFiled: Mar 2024 │ Granted: Jan 2025\u001b[0m\r\n"]
[0.001, "o", "  Describes a quantization-aware training method for deploying\r\n  large language models under 4GB memory constraints.\r\n\r\n"]
[0.212, "o", "  \u001b[1mUS-2025-0298741\u001b[0m — Speculative Decoding for On-Device Language Models\r\n  \u001b[2mFiled: Jun 2024 │ Granted: Apr 2025\u001b[0m\r\n"]
[0.000, "o", "  Uses a small draft model to predict token sequences, verified\r\n  by the larger model — 3x faster inference on Apple Silicon.\r\n\r\n"]
[0.212, "o", "  \u001b[1mUS-2026-0051283\u001b[0m — Adaptive Context Window Management\r\n"]
[0.000, "o", "  \u001b[2mFiled: Sep 2024 │ Published: Feb 2026\u001b[0m\r\n"]
[0.000, "o", "  Dynamic attention pruning that maintains quality while reducing\r\n"]
[0.000, "o", "  KV-cache memory by 60% for long conversations.\r\n\r\n"]
