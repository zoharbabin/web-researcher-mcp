[0.911, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  Go 1.23 extends \u001b[38;2;177;185;249mfor/range\u001b[39m to work with user-defined container types by allowing you to range over specific function signatures. The supported\u001b[K\r\u001b[1B  signatures\u001b[14Gare:\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[34mfunc\u001b[39m(yield \u001b[34mfunc\u001b[33m()\u001b[39m bool)\u001b[K\r\r\n\u001b[3G\u001b[34mfunc\u001b[39m(yield\u001b[14G\u001b[34mfunc\u001b[33m(V)\u001b[22G\u001b[39mbool)\r\r\n\u001b[3G\u001b[34mfunc\u001b[39m(yield\u001b[14G\u001b[34mfunc\u001b[33m(K,\u001b[22GV)\u001b[25G\u001b[39mbool)\r\r\n\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[39m\r\r\n\u001b[38;2;153;153;153mвқҜВ \u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"]
